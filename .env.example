# Optional in local development. Required to persist encrypted Threads storageState.
# Generate with: openssl rand -hex 32
AUTO_SOCIAL_SESSION_KEY=

# Optional. If unset, key-manager sync is disabled but manual key import still works.
KEY_MANAGER_URL=

# Optional. If unset, admin APIs only allow loopback requests.
ADMIN_TOKEN=

HOST_PORT=4323
CORS_ORIGIN=https://social.sisihome.org
